{
  "name": "kenshi-questpay",
  "version": "0.1.0",
  "packageManager": "pnpm@10.17.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "wallet:create": "tsx scripts/create-dev-wallet.ts",
    "wallet:balance": "tsx scripts/check-deployer-balance.ts",
    "deploy:contract": "echo \"Production uses direct Polygon transfers. Legacy testnet contract scripts are archived under scripts/legacy-testnet.\" && exit 1",
    "test": "node --test tests/**/*.test.mjs",
    "qa": "npm run lint && npm run typecheck && npm run test && npm run build && npm run test:e2e",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test qa/readability.spec.ts"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "3.0.4",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-query": "^5",
    "ethers": "^6",
    "framer-motion": "^12.42.2",
    "gsap": "^3.12.5",
    "lucide-react": "^1.25.0",
    "next": "^15.5.21",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "postprocessing": "6.39.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "server-only": "^0.0.1",
    "three": "^0.185.1",
    "viem": "^2",
    "wagmi": "^2.19.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.21",
    "hardhat": "^2.22.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
