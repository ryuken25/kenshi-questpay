NEXT_PUBLIC_SITE_URL=https://kenshi-questpay.vercel.app
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Client wallet-pay CTA + server release kill-switch (FAIL-SAFE).
# Real payments / on-chain release are enabled ONLY when this is exactly `true`.
# Unset, empty, false, or anything else → disabled. There is no implicit
# "enable because secrets exist" path — a preview deploy that forgets this flag
# can never silently move real funds. Set to `true` in production only after the
# real-payment gate checklist passes.
NEXT_PUBLIC_ENABLE_REAL_PAYMENTS=false

# Server-side Polygon RPC. POLYGON_RPC_URL is the primary (alias). For resilience,
# set POLYGON_RPC_URLS as a comma-separated list (primary first) — reads fail over
# on timeout(4s)/429/5xx to the next endpoint. Public fallbacks are also built in.
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
POLYGON_RPC_URLS=
# Custodial escrow receive address. Buyers pay INTO this address; the server
# later releases funds to the creator wallet. See docs/SECURITY.md (custodial model).
QUESTPAY_RECEIVE_ADDRESS=
# Server-only custody release signer — MUST control QUESTPAY_RECEIVE_ADDRESS.
# Never expose to client / NEXT_PUBLIC_*. Absent key → release endpoint refuses safely
# (funds stay in custody). This key never enables payments on its own — the
# NEXT_PUBLIC_ENABLE_REAL_PAYMENTS=true flag is still required (fail-safe gate above).
QUESTPAY_RELEASE_PRIVATE_KEY=

POLYGON_USDT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
POLYGON_USDT_DECIMALS=6

# Native USDC by Circle on Polygon PoS. NOT bridged USDC.e (0x2791...84174).
# Verified on-chain: symbol USDC, 6 decimals. Source: developers.circle.com/stablecoins/usdc-contract-addresses
POLYGON_USDC_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
POLYGON_USDC_DECIMALS=6

# Official fxVERSE (Verse/Bitcoin.com) on Polygon. Verified on-chain: symbol fxVERSE, 18 decimals.
POLYGON_VERSE_ADDRESS=0xc708d6f2153933daa50b2d0758955be0a93a8fec
POLYGON_VERSE_DECIMALS=18

QUOTE_PRIMARY_PROVIDER_URL=https://api.coingecko.com/api/v3/simple/price
QUOTE_PRIMARY_PROVIDER_KEY=
QUOTE_SECONDARY_PROVIDER_URL=
QUOTE_SECONDARY_PROVIDER_KEY=
QUOTE_TTL_SECONDS=600
PAYMENT_WINDOW_SECONDS=1800
# On-chain confirmations required by verify-payment (server). Default 5 if unset.
PAYMENT_MIN_CONFIRMATIONS=5

# Neon / Postgres (preferred data plane after migration)
DATABASE_URL=

# Supabase (legacy data plane + Auth providers during migration)

ADMIN_EMAILS=
ADMIN_EMAIL=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_ADMIN_TO=
CREATOR_NOTIFICATION_EMAIL=

AUTH_SESSION_SECRET=
WALLET_NONCE_SECRET=

# Root super-admin bootstrap. Leave EMPTY in the public template — never commit a
# real personal email or wallet here. Admin identity is provisioned at runtime only.
# ROOT_SUPER_ADMIN_EMAIL=admin@example.com
# ROOT_SUPER_ADMIN_WALLETS=0xabc...,0xdef...   (comma-separated checksum addresses)
ROOT_SUPER_ADMIN_EMAIL=
ROOT_SUPER_ADMIN_WALLETS=

NEXT_PUBLIC_BUILD_SHA=
NEXT_PUBLIC_BUILD_TIME=
